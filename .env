# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Entra (Azure AD) – App Registration credentials
# Register your app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# ─────────────────────────────────────────────────────────────────────────────
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value
AZURE_TENANT_ID=your-directory-tenant-id

# ─────────────────────────────────────────────────────────────────────────────
# Flask
# Generate a strong random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=replace-with-a-random-secret-key
FLASK_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Optional API keys (leave blank to skip those checks)
# ─────────────────────────────────────────────────────────────────────────────

# AbuseIPDB – https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# VirusTotal – https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
